# Runtime identity and endpoints
BIDDER_CONFIG=config/campaigns.sample.json
BIDDER_PUBLIC_ENDPOINT=http://localhost:8080
BIDDER_OPENRTB_ENDPOINT=http://localhost:8080/openrtb
BIDDER_BUYER_ID=agency_bidder_1
BIDDER_SEAT=agency_seat_1
BIDDER_CURRENCY=USD

# OpenRTB buyer auth for local certification and ClearLedger fanout
BIDDER_OPENRTB_AUTH_TOKEN=replace-me
BIDDER_OPENRTB_SIGNING_SECRET=replace-me
BIDDER_OPENRTB_REQUIRE_AUTH=false
BIDDER_OPENRTB_REQUIRE_SIGNATURE=false
BIDDER_OPENRTB_SIGNATURE_SKEW_SECONDS=300

# OpenRTB compatibility
BIDDER_OPENRTB_ACCEPTED_VERSIONS=2.6,2.5
BIDDER_OPENRTB_OUTBOUND_VERSION=2.6
BIDDER_OPENRTB_COMPAT_PROFILE=openrtb_json
BIDDER_OPENRTB_PRESERVE_PARTNER_EXT=true

# HTTP runtime limits
BIDDER_HTTP_READ_HEADER_TIMEOUT_MS=500
BIDDER_HTTP_READ_TIMEOUT_MS=2000
BIDDER_HTTP_WRITE_TIMEOUT_MS=2000
BIDDER_HTTP_IDLE_TIMEOUT_MS=60000
BIDDER_HTTP_SHUTDOWN_TIMEOUT_MS=5000
BIDDER_MAX_REQUEST_BODY_BYTES=262144
BIDDER_MAX_HEADER_BYTES=16384

# Optional ClearLedger registration API
CLEARLEDGER_REGISTER_URL=
CLEARLEDGER_API_KEY=
